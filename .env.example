# =========================
# Database (PostgreSQL)
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=agendador
DB_PASSWORD=agendador_secret
DB_NAME=agendadorplus
DB_SSLMODE=disable
DATABASE_URL=postgres://agendador:agendador_secret@localhost:5432/agendadorplus?sslmode=disable

# =========================
# Backend Server
# =========================
SERVER_PORT=8080
SERVER_TIMEOUT=3s

# =========================
# JWT Auth
# =========================
JWT_SECRET=change-me-to-a-real-secret-in-production

# =========================
# Admin Seed (MVP)
# =========================
ADMIN_EMAIL=admin@agendadorplus.com
ADMIN_PASSWORD=admin123

# =========================
# Frontend (Vite)
# =========================
VITE_API_URL=http://localhost:8080
